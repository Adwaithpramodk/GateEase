# Root-level gitignore for the GateEase monorepo

# ── Python / Django ──────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.log
*.pot
*.sqlite3
*.sqlite3-journal
.env
local_settings.py

# Virtual environments (NEVER commit these - thousands of files)
envv/
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# Django collected static & media uploads
Gateesaenew/Gate/staticfiles/
Gateesaenew/Gate/media/

# Secrets (NEVER commit these)
firebase-service-account.json
google-services.json
secrets.json

# ── Flutter / Dart ────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
gateeaseapp/build/
gateeaseapp/.dart_tool/
/coverage/

# Build artifacts
app.*.symbols
app.*.map.json
gateeaseapp/android/app/debug/
gateeaseapp/android/app/profile/
gateeaseapp/android/app/release/

# ── IDE ───────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db
